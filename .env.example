# .env.example — Plantilla de variables de entorno
# Copiar a .env y completar con valores reales. NUNCA commitear .env.

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Topics (pueden sobreescribirse; los defaults están en el código)
KAFKA_TOPIC_TRADES=crypto-trades
KAFKA_TOPIC_BOOK=crypto-book
KAFKA_TOPIC_FEATURES=crypto-features
KAFKA_TOPIC_PREDICTIONS=crypto-pred

# ─── Exchange e ingesta ───────────────────────────────────────────────────────
EXCHANGE_DEFAULT=binance_futures

# Lista de pares separados por coma (sin espacios), convención sin barra, mayúsculas
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,MATICUSDT,AVAXUSDT,DOTUSDT

# WebSocket — Binance USDS-Margined Futures
BINANCE_FUTURES_WS_BASE_URL=wss://stream.binance.com:9443/stream
BINANCE_FUTURES_WS_API_URL=wss://ws-fapi.binance.com/ws-fapi/v1

# Keepalive: Binance hace ping cada 3 min; desconecta si no hay pong en 10 min
WEBSOCKET_PING_INTERVAL_SECONDS=180     # intervalo de ping del servidor (referencia, no configurable en cliente)
WEBSOCKET_PONG_TIMEOUT_SECONDS=600      # timeout antes de reconectar
WEBSOCKET_MAX_RETRIES=0                 # 0 = sin límite (productor de larga duración)
WEBSOCKET_MAX_CONNECTION_LIFETIME_SECONDS=82800  # 23 h — reconectar antes de que el servidor fuerce a las 24 h

# ─── Spark ────────────────────────────────────────────────────────────────────
SPARK_CHECKPOINT_BASE=/tmp/spark-checkpoints   # ruta en WSL; cambiar si se quiere persistencia

# Host: ASUS TUF F15 — i7-12700H / 32 GB RAM / RTX 4070 Laptop 8 GB VRAM
# Configuración recomendada (ajustar si hay otros procesos corriendo)
SPARK_DRIVER_MEMORY=8g
SPARK_EXECUTOR_MEMORY=16g
SPARK_EXECUTOR_CORES=10
SPARK_SQL_SHUFFLE_PARTITIONS=20

# ─── Almacenamiento local ─────────────────────────────────────────────────────
# Reemplazar <usuario> con el nombre de usuario de WSL
DATA_DIR=/home/<usuario>/data/crypto
MODEL_DIR=/home/<usuario>/models/crypto

# Power BI lee desde Windows con ruta: \\wsl$\Ubuntu\home\<usuario>\data\crypto

# ─── RAPIDS (GPU) — RTX 4070 Laptop 8 GB VRAM ────────────────────────────────
# Pin verificado (mayo 2026): rapids-4-spark 24.10.1 + PySpark 3.5.2 en WSL (CUDA 12.x).
# No usar Redis en este stack; el mensajeo es Kafka y la GPU usa el plugin RAPIDS.
RAPIDS_JAR_PATH=/home/<usuario>/jars/rapids-4-spark_2.12-24.10.1.jar
# Opcional si tu distribución RAPIDS lo exige (builds recientes suelen bundle-ar cuDF):
# CUDF_JAR_PATH=/home/<usuario>/rapids-jars/cudf-25.02.0-cuda12.jar
# SPARK_RAPIDS_PINNED_POOL_SIZE=2g
